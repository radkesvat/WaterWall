{
  "name": "speedtest-tcp-over-udp-direct-pair",
  "nodes": [
    {
      "name": "speedtest-client",
      "type": "SpeedTestClient",
      "settings": {
        "mode": "tcp",
        "direction": "bidirectional",
        "duration-ms": 2000,
        "warmup-ms": 250,
        "report-interval-ms": 1000,
        "connection-count": 1,
        "payload-size": 32768,
        "target-megabits-per-sec": 300,
        "json-summary": true,
        "terminate-on-complete": true
      },
      "next": "tou-client"
    },
    {
      "name": "tou-client",
      "type": "TcpOverUdpClient",
      "next": "tou-server"
    },
    {
      "name": "tou-server",
      "type": "TcpOverUdpServer",
      "next": "speedtest-server"
    },
    {
      "name": "speedtest-server",
      "type": "SpeedTestServer",
      "settings": {
        "report-interval-ms": 1000,
        "json-summary": true,
        "quiet": false
      }
    }
  ]
}
