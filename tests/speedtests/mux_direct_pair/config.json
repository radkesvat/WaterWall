{
  "name": "speedtest-mux-direct-pair",
  "nodes": [
    {
      "name": "speedtest-client",
      "type": "SpeedTestClient",
      "settings": {
        "mode": "tcp",
        "direction": "bidirectional",
        "duration-ms": 2000,
        "warmup-ms": 250,
        "report-interval-ms": 1000,
        "connection-count": 16,
        "payload-size": 32768,
        "json-summary": true,
        "terminate-on-complete": true
      },
      "next": "mux-client"
    },
    {
      "name": "mux-client",
      "type": "MuxClient",
      "settings": {
        "mode": "fixed-connections-count",
        "per-worker-connections-count": 1,
        "child-buffer-limit": 67108864,
        "child-buffer-pause-tolerance": 1048576
      },
      "next": "mux-server"
    },
    {
      "name": "mux-server",
      "type": "MuxServer",
      "settings": {
        "child-buffer-limit": 67108864,
        "child-buffer-pause-tolerance": 1048576
      },
      "next": "speedtest-server"
    },
    {
      "name": "speedtest-server",
      "type": "SpeedTestServer",
      "settings": {
        "report-interval-ms": 1000,
        "json-summary": true,
        "quiet": false
      }
    }
  ]
}
