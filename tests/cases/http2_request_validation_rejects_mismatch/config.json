{
  "name": "http2-request-validation-rejects-mismatch",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "allow-early-response": true,
        "chunk-count": 1
      },
      "next": "http-client"
    },
    {
      "name": "http-client",
      "type": "HttpClient",
      "settings": {
        "host": "wrong-h2.example.test",
        "path": "/wrong/h2",
        "scheme": "http",
        "port": 80,
        "method": "GET",
        "http-version": "2",
        "full-duplex": true
      },
      "next": "http-server"
    },
    {
      "name": "http-server",
      "type": "HttpServer",
      "settings": {
        "http-version": "2",
        "host": "expected-h2.example.test",
        "path": "/expected/h2",
        "method": "POST",
        "status": 200,
        "full-duplex": true
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "streaming-response": true,
        "chunk-count": 1
      }
    }
  ]
}
