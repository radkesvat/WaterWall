{
  // whole-line comments should be ignored before JSON parsing
  "name": "config-variables-roundtrip",
  "variables": {
    "listener_address": "127.0.0.1",
    "listener_port": 45123, // end-of-line comments should work too
    "connect_target": "127.0.0.1",
    "connect_port": 45123,
    "whitelisted_ips": [
      "127.0.0.1/32",
      "::1/128"
    ],
    "delay_min_ms": 0,
    "delay_max_ms": 0
  },
  "nodes": [

    {
      "name": "tester-client-2",
      "type": "TesterClient",
      "next": "tcp-connector-2"
    },
    {
      "name": "tcp-connector-2",
      "type": "TcpConnector",
      "settings": {
        // comments should not break variable replacement
        "address": $connect_target$,
        "port": $connect_port$,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "tcp-listener-2",
      "type": "TcpListener",
      "settings": {
        "address": $listener_address$,
        "port": $listener_port$,
        "whitelist": $whitelisted_ips$,
        "nodelay": true
      },
      "next": "tester-server-2"
    },
    {
      "name": "tester-server-2",
      "type": "TesterServer"
    }
  ]
}
