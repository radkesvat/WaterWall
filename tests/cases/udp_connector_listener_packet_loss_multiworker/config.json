{
  "name": "udp-connector-listener-packet-loss-multiworker",
  "nodes": [
    {
      "name": "packet-sender",
      "type": "PacketSender",
      "settings": {
        "source-ipv4-range": "198.51.110.0/29",
        "dest-ipv4": "203.0.113.30",
        "protocol-number": "UDP",
        "src-port": 25900,
        "dest-port": 25910,
        "duration-ms": 200,
        "packets-per-ip": 8
      },
      "next": "udp-connector"
    },
    {
      "name": "udp-connector",
      "type": "UdpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 25920
      }
    },
    {
      "name": "udp-listener",
      "type": "UdpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 25920
      },
      "next": "packet-receiver"
    },
    {
      "name": "packet-receiver",
      "type": "PacketReceiver",
      "settings": {
        "source-ipv4-range": "198.51.110.0/29",
        "expected-packets-per-ip": 8,
        "report-after-ms": 1200,
        "output-file": "packet-receiver-report.txt"
      }
    }
  ]
}
