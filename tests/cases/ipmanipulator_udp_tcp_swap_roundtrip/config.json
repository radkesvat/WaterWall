{
  "name": "ipmanipulator-udp-tcp-swap-roundtrip",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "packet-mode": true,
        "packet-start-immediately": true,
        "max-payload-size": 24,
        "packet-ipv4": {
          "source-ip": "10.84.0.1",
          "dest-ip": "10.84.0.2",
          "protocol": 17,
          "ttl": 64
        }
      },
      "next": "packet-anchor"
    },
    {
      "name": "packet-anchor",
      "type": "IpOverrider",
      "settings": {
        "up": {
          "source-ip": {
            "ipv4": "10.84.0.1",
            "chance": 0
          }
        }
      },
      "next": "ip-manipulator"
    },
    {
      "name": "ip-manipulator",
      "type": "IpManipulator",
      "settings": {
        "protoswap-tcp": 17,
        "protoswap-udp": 6
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "packet-mode": true,
        "packet-init-on-start": true,
        "max-payload-size": 24,
        "packet-ipv4": {
          "source-ip": "10.84.0.1",
          "dest-ip": "10.84.0.2",
          "protocol": 6,
          "ttl": 64
        }
      }
    }
  ]
}
