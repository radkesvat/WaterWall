{
  "name": "packet-analysis-disturber-loss",
  "nodes": [
    {
      "name": "sender",
      "type": "PacketSender",
      "settings": {
        "source-ip4-range": "198.51.100.0/31",
        "dest-ipv4": "203.0.113.10",
        "protocol-number": "ICMP",
        "duration-ms": 100,
        "packets-per-ip": 3
      },
      "next": "loss"
    },
    {
      "name": "loss",
      "type": "Disturber",
      "settings": {
        "disturb-upstream": true,
        "disturb-downstream": false,
        "chance_payload_loss": 100
      },
      "next": "receiver"
    },
    {
      "name": "receiver",
      "type": "PacketReceiver",
      "settings": {
        "source-ip4-range": "198.51.100.0/31",
        "expected-packets-per-ip": 3,
        "report-after-ms": 700,
        "output-file": "packet-receiver-report.txt"
      }
    }
  ]
}
