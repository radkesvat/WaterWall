{
  "name": "socks5-noauth-dest-protocol-tcp-loopback",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "dest-context": {
          "address": "127.0.0.1",
          "port": 42631,
          "protocol": "tcp"
        }
      },
      "next": "socks5-client"
    },
    {
      "name": "socks5-client",
      "type": "Socks5Client",
      "settings": {
        "address": "dest_context->address",
        "port": "dest_context->port",
        "protocol": "dest_context->protocol"
      },
      "next": "proxy-connector"
    },
    {
      "name": "proxy-connector",
      "type": "TcpUdpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 42630,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "proxy-listener",
      "type": "TcpUdpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42630,
        "nodelay": true
      },
      "next": "socks5-server"
    },
    {
      "name": "socks5-server",
      "type": "Socks5Server",
      "settings": {
        "no-auth": true,
        "connect": true,
        "udp": true,
        "ipv4": "127.0.0.1"
      },
      "next": "target-connector"
    },
    {
      "name": "target-connector",
      "type": "TcpUdpConnector",
      "settings": {
        "address": "dest_context->address",
        "port": "dest_context->port",
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "target-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42631,
        "nodelay": true
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer"
    }
  ]
}
