{
  "name": "vless-uuid-udp-loopback",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "max-payload-size": 1200,
        "split-payload-burst": 4,
        "dest-context": {
          "address": "127.0.0.1",
          "port": 42821,
          "protocol": "udp"
        }
      },
      "next": "vless-client"
    },
    {
      "name": "vless-client",
      "type": "VlessClient",
      "settings": {
        "uuid": "5783a3e7-e373-51cd-8642-c83782b807c5",
        "address": "dest_context->address",
        "port": "dest_context->port",
        "protocol": "dest_context->protocol"
      },
      "next": "proxy-connector"
    },
    {
      "name": "proxy-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 42820,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "proxy-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42820,
        "nodelay": true
      },
      "next": "vless-server"
    },
    {
      "name": "vless-server",
      "type": "VlessServer",
      "settings": {
        "uuid": "5783a3e7-e373-51cd-8642-c83782b807c5",
        "connect": false,
        "udp": true
      },
      "next": "target-connector"
    },
    {
      "name": "target-connector",
      "type": "UdpConnector",
      "settings": {
        "address": "dest_context->address",
        "port": "dest_context->port",
        "reuseaddr": false
      }
    },
    {
      "name": "target-listener",
      "type": "UdpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42821
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "max-payload-size": 1200,
        "split-payload-burst": 4
      }
    }
  ]
}
