{
  "name": "softiplimiter-trojan-tcp-loopback",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "dest-context": {
          "address": "127.0.0.1",
          "port": 42931,
          "protocol": "tcp"
        }
      },
      "next": "trojan-client"
    },
    {
      "name": "trojan-client",
      "type": "TrojanClient",
      "settings": {
        "password": "softiplimiter-trojan-password",
        "address": "dest_context->address",
        "port": "dest_context->port",
        "protocol": "dest_context->protocol"
      },
      "next": "tls-client"
    },
    {
      "name": "tls-client",
      "type": "TlsClient",
      "settings": {
        "sni": "trojan.integration.test",
        "verify": false
      },
      "next": "proxy-connector"
    },
    {
      "name": "proxy-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 42930,
        "nodelay": true,
        "fastopen": false
      }
    },
    {
      "name": "proxy-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42930,
        "nodelay": true
      },
      "next": "tls-server"
    },
    {
      "name": "tls-server",
      "type": "TlsServer",
      "settings": {
        "cert-file": "../tls_roundtrip/server.crt",
        "key-file": "../tls_roundtrip/server.key",
        "sni": "trojan.integration.test"
      },
      "next": "soft-limiter"
    },
    {
      "name": "soft-limiter",
      "type": "SoftIpLimiter",
      "settings": {
        "identifier": "trojan",
        "simultaneous-user-limit": 1,
        "tolerance-ms": 30000
      },
      "next": "trojan-server"
    },
    {
      "name": "trojan-server",
      "type": "TrojanServer",
      "settings": {
        "password": "softiplimiter-trojan-password",
        "connect": true,
        "udp": false
      },
      "next": "target-connector"
    },
    {
      "name": "target-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "dest_context->address",
        "port": "dest_context->port",
        "nodelay": true,
        "fastopen": false
      }
    },
    {
      "name": "target-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42931,
        "nodelay": true
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer"
    }
  ]
}

