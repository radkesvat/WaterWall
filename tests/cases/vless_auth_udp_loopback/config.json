{
  "name": "vless-auth-udp-loopback",
  "nodes": [
    {
      "name": "auth-client",
      "type": "AuthenticationClient",
      "settings": {
        "name": "edge-1",
        "secret": "vless-auth-secret",
        "ping-interval-ms": 0,
        "pull-interval-ms": 0,
        "push-interval-ms": 0,
        "reconnect-interval-ms": 1000,
        "request-timeout-ms": 5000,
        "max-pending-requests": 16
      },
      "next": "auth-db"
    },
    {
      "name": "auth-db",
      "type": "AuthenticationServer",
      "settings": {
        "db-path": "users.json",
        "file-save-rate-ms": 60000,
        "session-idle-timeout-ms": 600000,
        "auth-clients": [
          {
            "name": "edge-1",
            "secret": "vless-auth-secret",
            "allow-user-pull": true,
            "allow-stats-push": true,
            "allow-user-write": false
          }
        ]
      }
    },
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "max-payload-size": 3800,
        "split-payload-burst": 1
      },
      "next": "vless-client"
    },
    {
      "name": "vless-client",
      "type": "VlessClient",
      "settings": {
        "uuid": "5783a3e7-e373-51cd-8642-c83782b807c5",
        "address": "127.0.0.1",
        "port": 42861,
        "protocol": "udp"
      },
      "next": "proxy-connector"
    },
    {
      "name": "proxy-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 42860,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "proxy-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42860,
        "nodelay": true
      },
      "next": "vless-server"
    },
    {
      "name": "vless-server",
      "type": "VlessServer",
      "settings": {
        "auth-client-node-name": "auth-client",
        "connect": false,
        "udp": true
      },
      "next": "target-connector"
    },
    {
      "name": "target-connector",
      "type": "UdpConnector",
      "settings": {
        "address": "dest_context->address",
        "port": "dest_context->port",
        "reuseaddr": false
      }
    },
    {
      "name": "target-listener",
      "type": "UdpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42861
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "max-payload-size": 3800,
        "split-payload-burst": 1
      }
    }
  ]
}
