{
  "name": "tls-server-rejects-empty-snis",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "allow-early-response": true
      },
      "next": "tls-client"
    },
    {
      "name": "tls-client",
      "type": "TlsClient",
      "settings": {
        "sni": "server.empty.multi.sni.test",
        "verify": false
      },
      "next": "tls-server"
    },
    {
      "name": "tls-server",
      "type": "TlsServer",
      "settings": {
        "cert-file": "server.crt",
        "key-file": "server.key",
        "snis": []
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer"
    }
  ]
}
