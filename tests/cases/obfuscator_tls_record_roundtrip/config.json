{
  "name": "obfuscator-tls-record-roundtrip",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "packet-mode": true,
        "packet-start-immediately": true,
        "chunk-count": 9
      },
      "next": "obfuscator-client"
    },
    {
      "name": "obfuscator-client",
      "type": "ObfuscatorClient",
      "settings": {
        "method": "xor",
        "xor_key": 60,
        "skip": "none",
        "tls_record_header": true
      },
      "next": "obfuscator-client-bridge"
    },
    {
      "name": "obfuscator-client-bridge",
      "type": "Bridge",
      "settings": {
        "pair": "obfuscator-server-bridge"
      }
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "packet-mode": true,
        "packet-init-on-start": true,
        "chunk-count": 9
      },
      "next": "obfuscator-server"
    },
    {
      "name": "obfuscator-server",
      "type": "ObfuscatorServer",
      "settings": {
        "method": "xor",
        "xor_key": 60,
        "skip": "none",
        "tls_record_header": true
      },
      "next": "obfuscator-server-bridge"
    },
    {
      "name": "obfuscator-server-bridge",
      "type": "Bridge",
      "settings": {
        "pair": "obfuscator-client-bridge"
      }
    }
  ]
}
