      "type": "TcpOverUdpServer",
      "settings": {
        "fec": true,
        "fec-data-shards": 4,
        "fec-parity-shards": 2
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer"
    }
  ]
}
