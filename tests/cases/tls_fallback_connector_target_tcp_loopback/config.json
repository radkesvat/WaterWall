{
  "name": "tls-fallback-connector-target-tcp-loopback",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "chunk-count": 3
      },
      "next": "tcp-connector"
    },
    {
      "name": "tcp-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 42990,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "tcp-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42990,
        "nodelay": true
      },
      "next": "tls-server"
    },
    {
      "name": "tls-server",
      "type": "TlsServer",
      "settings": {
        "cert-file": "server.crt",
        "key-file": "server.key",
        "fallback-node-name": "fallback-connector"
      },
      "next": "protected-invalid"
    },
    {
      "name": "protected-invalid",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 9,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "fallback-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 42991,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "fallback-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42991,
        "nodelay": true
      },
      "next": "fallback-server"
    },
    {
      "name": "fallback-server",
      "type": "TesterServer",
      "settings": {
        "chunk-count": 3
      }
    }
  ]
}
