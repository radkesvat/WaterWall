{
  "name": "softiplimiter-identification-failure-close-probe",
  "nodes": [
    {
      "name": "proxy-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 43050,
        "nodelay": true
      },
      "next": "soft-limiter"
    },
    {
      "name": "soft-limiter",
      "type": "SoftIpLimiter",
      "settings": {
        "identifier": "vless",
        "simultaneous-user-limit": 1,
        "tolerance-ms": 30000,
        "on-identification-failure": "close",
        "verbose": true
      },
      "next": "blackhole"
    },
    {
      "name": "blackhole",
      "type": "BlackHole",
      "settings": {
        "mode": "passive"
      }
    }
  ]
}
