{
  "name": "tls-multi-sni-race",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "allow-early-response": true
      },
      "next": "tls-client"
    },
    {
      "name": "tls-client",
      "type": "TlsClient",
      "settings": {
        "snis": ["blocked.multi.sni.test", "allowed.multi.sni.test"],
        "sni-selection": "race",
        "race-tries": 2,
        "race-timeout-ms": 5000,
        "verify": false
      },
      "next": "tls-server"
    },
    {
      "name": "tls-server",
      "type": "TlsServer",
      "settings": {
        "cert-file": "server.crt",
        "key-file": "server.key",
        "snis": ["allowed.multi.sni.test"]
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "streaming-response": true
      }
    }
  ]
}
