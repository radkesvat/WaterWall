{
  "name": "softiplimiter-vless-tcp-loopback",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "dest-context": {
          "address": "127.0.0.1",
          "port": 42921,
          "protocol": "tcp"
        }
      },
      "next": "vless-client"
    },
    {
      "name": "vless-client",
      "type": "VlessClient",
      "settings": {
        "uuid": "5783a3e7-e373-51cd-8642-c83782b807c5",
        "address": "dest_context->address",
        "port": "dest_context->port",
        "protocol": "dest_context->protocol"
      },
      "next": "proxy-connector"
    },
    {
      "name": "proxy-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 42920,
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "proxy-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42920,
        "nodelay": true
      },
      "next": "soft-limiter"
    },
    {
      "name": "soft-limiter",
      "type": "SoftIpLimiter",
      "settings": {
        "identifier": "vless",
        "simultaneous-user-limit": 1,
        "tolerance-ms": 30000
      },
      "next": "vless-server"
    },
    {
      "name": "vless-server",
      "type": "VlessServer",
      "settings": {
        "uuid": "5783a3e7-e373-51cd-8642-c83782b807c5",
        "connect": true,
        "udp": false
      },
      "next": "target-connector"
    },
    {
      "name": "target-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "dest_context->address",
        "port": "dest_context->port",
        "nodelay": true,
        "fastopen": false,
        "reuseaddr": false
      }
    },
    {
      "name": "target-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 42921,
        "nodelay": true
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer"
    }
  ]
}

