{
  "name": "http1-bidirectional-roundtrip",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "allow-early-response": true
      },
      "next": "http-client"
    },
    {
      "name": "http-client",
      "type": "HttpClient",
      "settings": {
        "host": "http1.example.test",
        "path": "/ww/http1",
        "scheme": "http",
        "port": 80,
        "method": "POST",
        "http-version": "1.1",
        "full-duplex": true
      },
      "next": "http-server"
    },
    {
      "name": "http-server",
      "type": "HttpServer",
      "settings": {
        "http-version": "1.1",
        "host": "http1.example.test",
        "path": "/ww/http1",
        "method": "POST",
        "status": 200,
        "full-duplex": true
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "streaming-response": true
      }
    }
  ]
}
