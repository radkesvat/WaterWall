{
  "name": "http1-split-tcp-loopback",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "allow-early-response": true
      },
      "next": "http-client"
    },
    {
      "name": "http-client",
      "type": "HttpClient",
      "settings": {
        "host": "split-tcp.example.test",
        "path": "/edge",
        "scheme": "http",
        "port": 20650,
        "method": "PUT",
        "http-version": "1.1",
        "http1-mode": "split",
        "split": {
          "upload-method": "PUT",
          "download-method": "GET",
          "upload-path": "/edge/upload",
          "download-path": "/edge/download",
          "id-placement": "header",
          "id-name": "X-WW-Session",
          "direction-placement": "query",
          "direction-name": "flow",
          "upload-value": "send",
          "download-value": "recv",
          "token": "cookie-token",
          "token-placement": "cookie",
          "token-name": "wwtoken",
          "cache-bypass": true,
          "cache-bypass-name": "nocache",
          "upload-headers": {
            "X-WW-Upload": "1"
          },
          "download-headers": {
            "X-WW-Download": "1"
          }
        }
      },
      "next": "tcp-connector"
    },
    {
      "name": "tcp-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 20650,
        "nodelay": true,
        "fastopen": false
      }
    },
    {
      "name": "tcp-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 20650,
        "nodelay": true
      },
      "next": "http-server"
    },
    {
      "name": "http-server",
      "type": "HttpServer",
      "settings": {
        "http-version": "1.1",
        "http1-mode": "split",
        "host": "split-tcp.example.test",
        "path": "/edge",
        "method": "PUT",
        "status": 200,
        "split": {
          "upload-method": "PUT",
          "download-method": "GET",
          "upload-path": "/edge/upload",
          "download-path": "/edge/download",
          "id-placement": "header",
          "id-name": "X-WW-Session",
          "direction-placement": "query",
          "direction-name": "flow",
          "upload-value": "send",
          "download-value": "recv",
          "token": "cookie-token",
          "token-placement": "cookie",
          "token-name": "wwtoken"
        },
        "no-split-upload-buffering-limit": true
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer",
      "settings": {
        "streaming-response": true
      }
    }
  ]
}