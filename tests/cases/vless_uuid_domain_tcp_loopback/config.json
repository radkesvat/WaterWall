{
  "name": "vless-uuid-domain-tcp-loopback",
  "nodes": [
    {
      "name": "tester-client",
      "type": "TesterClient",
      "settings": {
        "dest-context": {
          "address": "localhost",
          "port": 26601,
          "protocol": "tcp"
        }
      },
      "next": "vless-client"
    },
    {
      "name": "vless-client",
      "type": "VlessClient",
      "settings": {
        "uuid": "5783a3e7-e373-51cd-8642-c83782b807c5",
        "address": "dest_context->address",
        "port": "dest_context->port",
        "protocol": "dest_context->protocol"
      },
      "next": "proxy-connector"
    },
    {
      "name": "proxy-connector",
      "type": "TcpConnector",
      "settings": {
        "address": "127.0.0.1",
        "port": 26600,
        "nodelay": true,
        "fastopen": false
      }
    },
    {
      "name": "proxy-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 26600,
        "nodelay": true
      },
      "next": "vless-server"
    },
    {
      "name": "vless-server",
      "type": "VlessServer",
      "settings": {
        "uuid": "5783a3e7-e373-51cd-8642-c83782b807c5",
        "connect": true,
        "udp": true
      },
      "next": "target-connector"
    },
    {
      "name": "target-connector",
      "type": "TcpUdpConnector",
      "settings": {
        "address": "dest_context->address",
        "port": "dest_context->port",
        "nodelay": true,
        "fastopen": false,
        "domain-strategy": "prefer-ipv4"
      }
    },
    {
      "name": "target-listener",
      "type": "TcpListener",
      "settings": {
        "address": "127.0.0.1",
        "port": 26601,
        "nodelay": true
      },
      "next": "tester-server"
    },
    {
      "name": "tester-server",
      "type": "TesterServer"
    }
  ]
}
